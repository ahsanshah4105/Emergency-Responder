<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />



    <application
        android:name=".core.constants.MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmergencyResponder">
        <activity
            android:name=".modules.SettingActivity"
            android:exported="false" />

        <service
            android:name=".modules.dashboard.ui.service.CrashDetectionService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:ignore="MissingClass">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FNC_DESCRIPTION"
                android:value="Detects car accidents using motion sensors." />
        </service>

        <activity
            android:name=".modules.dashboard.ui.EmergencyContactsActivity"
            android:exported="false" />
        <activity
            android:name=".modules.timestamp.ui.TimeStampActivity"
            android:exported="false" />
        <activity
            android:name=".modules.dashboard.ui.SafetyDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".modules.splash.ui.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".modules.onboarding.ui.OnboardingActivity"
            android:exported="true"></activity>
        <activity
            android:name=".modules.auth.ui.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".modules.auth.ui.SignUpActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".modules.auth.ui.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>