<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme (AppCompat compatible) -->
    <style name="Base.Theme.EmergencyResponder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Your custom theme values here -->
    </style>


    <style name="Theme.EmergencyResponder" parent="Base.Theme.EmergencyResponder" />


    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="android:padding">16dp</item>
        <item name="android:backgroundTint">@color/primaryColor</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Custom text style -->
    <style name="CustomText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/black</item>
        <item name="lineSpacing">5dp</item>
        <item name="android:textSize">24sp</item>
        <item name="fontFamily">@font/poppins_semibold</item>
    </style>

    <style name="CustomSubText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/subTextColor</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/inter_regular</item>
    </style>

    <style name="Theme.App" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="customStrokeColor">@color/stroke_color</item>
    </style>

    <style name="Theme.App.BlueBorder" parent="Theme.App">
        <item name="customStrokeColor">@color/primaryBlue</item>
        <item name="android:radius">200dp</item>
    </style>


    <style name="DashboardText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/subTextColor</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/inter_medium</item>
    </style>


</resources>
