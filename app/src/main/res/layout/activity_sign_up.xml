<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".modules.auth.ui.SignUpActivity">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/emergency_alert_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:src="@drawable/register_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/register_to_your_account"
            style="@style/CustomText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emergency_alert_image" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/join_to_enable_instant_safety"
            style="@style/CustomSubText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView" />


        <androidx.cardview.widget.CardView
            android:id="@+id/email_card"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            android:layout_width="match_parent"
            android:layout_marginTop="24dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="50dp"
            app:layout_constraintTop_toBottomOf="@+id/textView2">

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_shadow"
                android:hint="@string/enter_email"
                style="@style/CustomSubText"
                android:textColorHint="@color/hint_color"
                android:inputType="textEmailAddress"
                android:paddingLeft="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="16dp"
                android:textSize="14sp" />

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/phone_card"
            app:cardElevation="0dp"
            android:layout_marginTop="8dp"
            app:cardUseCompatPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="50dp"
            app:layout_constraintTop_toBottomOf="@+id/email_card">

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_shadow"
                android:hint="@string/enter_email"
                style="@style/CustomSubText"
                android:textColorHint="@color/hint_color"
                android:inputType="textEmailAddress"
                android:paddingLeft="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="16dp"
                android:textSize="14sp" />

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintTop_toBottomOf="@+id/phone_card">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                style="@style/CustomSubText"
                android:hint="@string/enter_password"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/primaryBlue"
                app:boxBackgroundMode="none"
                android:backgroundTint="@color/background_shadow"
                android:paddingBottom="10dp"
                app:hintAnimationEnabled="false"
                android:paddingRight="10dp"
                android:background="@color/background_shadow"
                android:textColorHint="@color/hint_color"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingLeft="16dp"
                    android:paddingTop="10dp"
                    android:textSize="14sp"
                    android:textColorHint="@color/hint_color"
                    android:background="@color/background_shadow"
                    android:inputType="textPassword"
                    android:minHeight="0dp"/>
            </com.google.android.material.textfield.TextInputLayout>


        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/confirm_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintTop_toBottomOf="@+id/cardView">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                style="@style/CustomSubText"
                android:hint="@string/confirm_password"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/primaryBlue"
                app:boxBackgroundMode="none"
                android:backgroundTint="@color/background_shadow"
                android:paddingBottom="10dp"
                app:hintAnimationEnabled="false"
                android:paddingRight="10dp"
                android:background="@color/background_shadow"
                android:textColorHint="@color/hint_color"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingLeft="16dp"
                    android:paddingTop="10dp"
                    android:textSize="14sp"
                    android:textColorHint="@color/hint_color"
                    android:background="@color/background_shadow"
                    android:inputType="textPassword"
                    android:minHeight="0dp"/>
            </com.google.android.material.textfield.TextInputLayout>


        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/emergency_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/black"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/emergency_contacts"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/confirm_password" />

        <androidx.cardview.widget.CardView
            android:id="@+id/emergency_Contact_Name"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            android:layout_width="match_parent"
            android:layout_marginTop="16dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="50dp"
            app:layout_constraintTop_toBottomOf="@+id/emergency_text">

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_shadow"
                android:hint="@string/enter_name"
                style="@style/CustomSubText"
                android:textColorHint="@color/hint_color"
                android:paddingLeft="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="16dp"
                android:textSize="14sp" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/emergency_Contact"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            android:layout_width="match_parent"
            android:layout_marginTop="8dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="50dp"
            app:layout_constraintTop_toBottomOf="@+id/emergency_Contact_Name">

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_shadow"
                android:hint="@string/enter_mobile_number"
                style="@style/CustomSubText"
                android:textColorHint="@color/hint_color"
                android:paddingLeft="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="16dp"
                android:textSize="14sp" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/add_more_contacts"
            android:layout_width="match_parent"
            android:layout_marginTop="24dp"
            android:layout_height="wrap_content"
            android:background="@drawable/border_line"
            android:theme="@style/Theme.App.BlueBorder"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emergency_Contact">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_more_contacts"
                android:fontFamily="@font/inter_medium"
                android:drawableStart="@drawable/round_add_24"
                android:textSize="16sp"
                android:layout_margin="16dp"
                android:textColor="@color/primaryBlue"
                android:gravity="center"
                />
        </LinearLayout>

        <Button
            android:id="@+id/button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/primaryColor"
            style="@style/AppButton"
            android:fontFamily="@font/nunito_semibold"
            android:text="@string/login_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/add_more_contacts" />

        <LinearLayout
            android:id="@+id/textt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/button"
            tools:layout_editor_absoluteX="48dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:text="@string/already_have_an_account"
                style="@style/CustomSubText" />

            <View
                android:layout_width="4dp"
                android:layout_height="1dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                />

            <TextView
                android:id="@+id/login_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/login"
                android:textColor="@color/primaryColor"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textt" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>